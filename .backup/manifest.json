{
    "name": "M6 Replay Only",
    "version": "0.1",
    "description": "Une extension chrome qui masque les sections indésirables sur M6.",
    "manifest_version": 3,
    "background": {
        "service_worker": "scripts/background.js"
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_icon": "assets/m6replay.png"
    }
}