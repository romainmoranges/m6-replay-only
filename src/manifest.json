{
    "name": "M6 Replay Only",
    "short_name": "M6 Replay Only",
    "description": "Une extension chrome qui masque les sections indésirables sur M6.",
    "homepage_url": "http://chrome.google.com/webstore",
    "version": "0.0.1",
    "version_name": "0.0.1",
    "manifest_version": 3,
    "minimum_chrome_version": "88",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "icons": {
        "128": "assets/img/128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_icon": {
            "16": "assets/img/16.png",
            "32": "assets/img/32.png",
            "64": "assets/img/64.png",
            "128": "assets/img/128.png"
        },
        "default_title": "M6 Replay Only"
    }
}